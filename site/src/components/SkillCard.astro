---
interface Props {
  rank?: number;
  name: string;
  slug: string;
  repo_url: string;
  stars: number;
  score_final: number;
  domains: string[];
  tags: string[];
  ai_summary: string;
  ai_strengths: string[];
  ai_weaknesses: string[];
  license: string;
  latest_release: string;
  has_skill_md: boolean;
  has_references: boolean;
  has_scripts: boolean;
  has_examples: boolean;
}

const {
  rank,
  name,
  repo_url,
  stars,
  score_final,
  domains,
  tags,
  ai_summary,
  ai_strengths,
  ai_weaknesses,
  license,
  latest_release,
  has_skill_md,
  has_references,
  has_scripts,
  has_examples,
} = Astro.props;

function scoreColor(score: number): string {
  if (score >= 70) return 'var(--green)';
  if (score >= 50) return 'var(--yellow)';
  if (score >= 30) return 'var(--orange)';
  return 'var(--red)';
}

function formatStars(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1) + 'k';
  return n.toString();
}

const badges: string[] = [];
if (has_skill_md) badges.push('SKILL.md');
if (has_references) badges.push('refs');
if (has_scripts) badges.push('scripts');
if (has_examples) badges.push('examples');
if (latest_release) badges.push(latest_release);
---

<div class="skill-card">
  <div class="card-header">
    <div class="score" style={`border-color: ${scoreColor(score_final)}`}>
      {rank && <span class="rank">#{rank}</span>}
      <span class="score-value" style={`color: ${scoreColor(score_final)}`}>
        {score_final.toFixed(1)}
      </span>
    </div>
    <div class="title-area">
      <h3><a href={repo_url} target="_blank" rel="noopener">{name}</a></h3>
      <div class="meta">
        {stars > 0 && <span class="stars">{formatStars(stars)} stars</span>}
        {license && <span class="license">{license}</span>}
        {domains.map(d => <span class="domain">{d}</span>)}
      </div>
    </div>
  </div>

  {ai_summary && <p class="summary">{ai_summary}</p>}

  <div class="details">
    {ai_strengths.length > 0 && (
      <div class="pros">
        {ai_strengths.map(s => <span class="pro">+ {s}</span>)}
      </div>
    )}
    {ai_weaknesses.length > 0 && (
      <div class="cons">
        {ai_weaknesses.map(w => <span class="con">- {w}</span>)}
      </div>
    )}
  </div>

  <div class="badges">
    {badges.map(b => <span class="badge">{b}</span>)}
    {tags.slice(0, 4).map(t => <span class="tag">{t}</span>)}
  </div>
</div>

<style>
  .skill-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    margin-bottom: 1rem;
    transition: background 0.15s;
  }

  .skill-card:hover {
    background: var(--bg-hover);
  }

  .card-header {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .score {
    display: flex;
    flex-direction: column;
    align-items: center;
    border: 2px solid;
    border-radius: 8px;
    padding: 0.4rem 0.6rem;
    min-width: 55px;
  }

  .rank {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .score-value {
    font-size: 1.3rem;
    font-weight: 700;
  }

  .title-area {
    flex: 1;
  }

  .title-area h3 {
    font-size: 1.1rem;
    margin-bottom: 0.3rem;
  }

  .meta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .domain {
    background: rgba(99, 102, 241, 0.15);
    color: var(--accent-light);
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
  }

  .summary {
    margin: 0.75rem 0;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .details {
    display: flex;
    gap: 1.5rem;
    margin: 0.5rem 0;
    font-size: 0.8rem;
  }

  .pros, .cons {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .pro {
    color: var(--green);
  }

  .con {
    color: var(--orange);
  }

  .badges {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }

  .badge {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--border);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .tag {
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.2);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.7rem;
    color: var(--green);
  }
</style>
